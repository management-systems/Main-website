{
  "version": 2,
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/admin/api/(.*)", "destination": "/api/index.js" },
    { "source": "/admin/login", "destination": "/api/index.js" },
    { "source": "/admin/login/", "destination": "/api/index.js" },
    { "source": "/admin/logout", "destination": "/api/index.js" },
    { "source": "/admin/logout/", "destination": "/api/index.js" },
    { "source": "/admin/dashboard", "destination": "/api/index.js" },
    { "source": "/admin/dashboard/", "destination": "/api/index.js" },
    { "source": "/admin", "destination": "/api/index.js" },
    { "source": "/admin/", "destination": "/api/index.js" }
  ]
}
